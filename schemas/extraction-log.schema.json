{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "Extraction Log",
  "properties": {
    "case_id": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "confidence": {
            "enum": [
              "high",
              "medium",
              "low",
              "failed"
            ]
          },
          "uncertain_areas": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "case_id",
    "files"
  ]
}
